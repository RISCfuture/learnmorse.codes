{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["src/**/*.{ts,vue}", "tests/**/*.ts"],
  "ignore": [],
  "ignoreDependencies": [
    "@pinia/testing",
    "@testing-library/vue",
    "@types/setimmediate",
    "@vue/compiler-dom",
    "@vue/test-utils",
    "postcss",
    "setimmediate",
    "start-server-and-test"
  ],
  "vitest": {
    "entry": ["src/**/__tests__/*.spec.ts", "tests/unit/**/*.spec.ts", "tests/unit/setup.ts"]
  },
  "rules": {
    "exports": "warn",
    "unresolved": "off"
  },
  "ignoreExportsUsedInFile": true
}
